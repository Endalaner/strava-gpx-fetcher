# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token

# Strava API Credentials (from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_ADMIN_REFRESH_TOKEN=your_refresh_token

# Database Credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=strava_bot

# OpenWeatherMap API Key (Free Tier 2.5/forecast supported)
OPENWEATHER_API_KEY=your_owm_api_key
